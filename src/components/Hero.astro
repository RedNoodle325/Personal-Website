---
---

<section
  id="about"
  class="min-h-screen flex items-center justify-center px-6 pt-20 pb-16"
>
  <div class="max-w-3xl w-full">
    <!-- Greeting -->
    <p class="font-mono text-accent text-sm tracking-widest uppercase mb-4">
      Hello, I'm
    </p>

    <!-- Name -->
    <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold text-slate-100 leading-tight mb-4">
      Zak Klinedinst
    </h1>

    <!-- Title -->
    <h2 class="text-xl sm:text-2xl text-accent font-mono mb-8">
      Project Manager, Munters Data Center Technologies
    </h2>

    <!-- Bio -->
    <p class="text-slate-400 text-lg leading-relaxed max-w-2xl mb-10">
      I manage and deliver complex data center projects from concept to commissioning.
      Passionate about operational efficiency, cross-functional collaboration, and
      building things that work at scale. Here you'll find a few of the personal
      projects I've built along the way.
    </p>

    <!-- CTAs -->
    <div class="flex flex-wrap gap-4">
      <a
        href="#projects"
        class="inline-flex items-center gap-2 bg-accent text-slate-900 font-semibold px-6 py-3 rounded-lg hover:bg-accent-glow transition-colors duration-200"
      >
        View My Work
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </a>
      <a
        href="#contact"
        class="inline-flex items-center gap-2 border border-surface-border text-slate-300 font-semibold px-6 py-3 rounded-lg hover:border-accent hover:text-accent transition-colors duration-200"
      >
        Get In Touch
      </a>
    </div>
  </div>

  <!-- Decorative dot grid -->
  <div
    class="absolute inset-0 -z-10 opacity-20"
    style="background-image: radial-gradient(circle, #334155 1px, transparent 1px); background-size: 32px 32px;"
  ></div>
</section>
