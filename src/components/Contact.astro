---

<section id="contact" class="py-24 px-6">
  <div class="max-w-3xl mx-auto text-center">
    <p class="font-mono text-accent text-sm tracking-widest uppercase mb-2">Say Hello</p>
    <h2 class="text-3xl sm:text-4xl font-bold text-slate-100 mb-6">Get In Touch</h2>

    <p class="text-slate-400 text-lg leading-relaxed mb-12 max-w-xl mx-auto">
      Whether you want to talk shop, collaborate on a project, or just connect — my inbox is open.
    </p>

    <!-- Social icons -->
    <div class="flex justify-center gap-6">
      {socials.map((social) => (
        <a
          href={social.href}
          target={social.label !== 'Email' ? '_blank' : undefined}
          rel={social.label !== 'Email' ? 'noopener noreferrer' : undefined}
          class="flex flex-col items-center gap-2 text-slate-400 hover:text-accent transition-colors duration-200 group"
          aria-label={social.label}
        >
          <span class="p-3 border border-surface-border rounded-lg group-hover:border-accent transition-colors duration-200" set:html={social.icon} />
          <span class="text-xs font-mono">{social.label}</span>
        </a>
      ))}
    </div>
  </div>
</section>
